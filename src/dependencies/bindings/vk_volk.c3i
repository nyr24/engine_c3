macro @make_api_version(#variant, #major, #minor, #patch) {
  return (((uint)(#variant)) << 29U) | (((uint)(#major)) << 22U) | (((uint)(#minor)) << 12U) | ((uint)(#patch));
}

const HEADER_VERSION = 341;
const HEADER_VERSION_COMPLETE = @make_api_version(0,1,4,HEADER_VERSION);

macro @make_version(#major, #minor, #patch) {
  return (((uint)(#major)) << 22U) | (((uint)(#minor)) << 12U) | ((uint)(#patch));
}

macro @api_version_variant(#version) {
  return (uint)(#version) >> 29U;
}

macro @api_version_major(#version) {
  return ((uint)(#version) >> 22U) & 0x7FU;
}

macro @api_version_minor(#version) {
  return ((uint)(#version) >> 12U) & 0x3FFU;
}

macro @api_version_patch(#version) {
  return (uint)(#version) & 0xFFFU;
}

